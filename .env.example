# Public site identity
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="GridSpell Studio"
NEXT_PUBLIC_CONTACT_EMAIL=hello@gridspellstudio.com
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Hosted Supabase: use the Project Connect dialog.
# Local Supabase: run `npx supabase status` and copy the local values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Used only by local seed scripts. Never use this as a real password.
AUTH_TEST_PASSWORD=GridSpell-Test-2026!

# Stripe. Use sk_test/pk_test locally and live keys only in Vercel Production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=
STRIPE_WEBHOOK_TEST_URL=http://127.0.0.1:3000

# Resend transactional email.
RESEND_API_KEY=
RESEND_FROM_EMAIL="GridSpell Studio <notifications@send.gridspellstudio.com>"
RESEND_REPLY_TO=hello@gridspellstudio.com
ADMIN_NOTIFICATION_EMAIL=hello@gridspellstudio.com
EMAIL_TEST_TO=

# Phase 8: lead-form abuse protection.
# Generate RATE_LIMIT_SALT with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RATE_LIMIT_SALT=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_EXPECTED_HOSTNAME=gridspellstudio.com

# Phase 8: analytics.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Phase 8: Sentry error monitoring.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
