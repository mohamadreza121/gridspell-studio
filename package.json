{
  "name": "gridspell-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "check": "npm run type-check && npm run lint && npm run build",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset",
    "supabase:test": "supabase test db",
    "supabase:types": "supabase gen types typescript --local > src/types/database.generated.ts",
    "auth:seed": "node --env-file=.env.local scripts/seed-auth-users.mjs",
    "auth:bootstrap-owner": "node --env-file=.env.local scripts/bootstrap-owner.mjs",
    "portal:seed": "node --env-file=.env.local scripts/seed-portal-demo.mjs",
    "email:test": "node --env-file=.env.local scripts/send-test-email.mjs",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/stripe/webhook",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:accessibility": "playwright test tests/e2e/accessibility.spec.ts --project=desktop-chromium",
    "test:responsive": "playwright test tests/e2e/responsive.spec.ts",
    "test:reduced-motion": "playwright test tests/e2e/reduced-motion.spec.ts --project=desktop-chromium",
    "test:performance": "playwright test tests/e2e/performance.spec.ts --project=desktop-chromium",
    "stripe:test-webhook": "node --env-file=.env.local scripts/test-stripe-webhook.mjs",
    "quality:phase8": "npm run check && npm run performance:assets && npm run test:accessibility && npm run test:responsive && npm run test:reduced-motion && npm run test:performance",
    "performance:assets": "node scripts/check-asset-budget.mjs"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.62.0",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.21.0",
    "motion": "12.41.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "^6.14.0",
    "stripe": "^22.2.3",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.9",
    "prettier": "3.8.4",
    "supabase": "^2.108.0",
    "tailwindcss": "4.3.1",
    "typescript": "5.9.3"
  }
}
